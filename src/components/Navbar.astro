<script>
  const activateLink = () => {
    const link = document.querySelector(`a[href="${window.location.pathname}"]`);
    link.id = "active";
    link.classList.add("pageLink");
  }
  activateLink();
  document.addEventListener("astro:after-swap", activateLink)
</script>

