---
const { title, desc, date, link, linkName } = Astro.props;
---

<script>
  const cards = document.querySelectorAll("div.card");

  cards.forEach((card) => {
    card.addEventListener("click", () => {
      location.href = card.getAttribute("data-link")!;
    });
  });
</script>

<div class="card" data-link={link}>
  <span class="cardTitle"><strong>{title}</strong></span>
  <span class="cardDesc">{desc}</span>
  <div class="cardDetails">
    <span class="cardDate"><i>{date}</i></span>
    <a href={link} class="cardLink noLinkHover">{linkName}</a>
  </div>
</div>

<style scoped>
  .card {
    width: 90%;
    min-height: 50px;
    border: 1px solid var(--color);
    padding: 15px;
    margin: 15px auto 5px auto;
    
    &:hover {
        cursor: pointer;
    }
  }

  .cardTitle {
    font-size: 1.2rem;
    display: block;
    margin-bottom: 10px;
  }

  .cardDetails {
    margin-top: 10px;
    font-size: 0.9rem;
    display: flex;
    justify-content: space-between;
  }
</style>
